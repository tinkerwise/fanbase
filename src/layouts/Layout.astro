---
const { title = 'Baltimore Orioles Fanbase' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <img src="/logo.svg" alt="Baltimore Orioles" width="46" height="46" class="team-logo" />
      <h1 class="site-title">Orioles Fanbase</h1>
      <nav class="site-nav">
        <a href="/">Home</a>
      </nav>
    </div>
  </header>
  <main class="site-main">
    <slot />
  </main>
  <footer class="site-footer">
    <p>Fanbase &copy; {new Date().getFullYear()} &mdash; Fan-run. Not affiliated with MLB.</p>
  </footer>
</body>
</html>
